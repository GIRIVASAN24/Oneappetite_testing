<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OneAppetite Parallel Regression" verbose="1" parallel="classes" thread-count="3">
    <listeners>
        <listener class-name="com.cts.mfrp.oneappetite.utils.ExtentReportListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="headless" value="true"/>

    <test name="All Tests (parallel by class)">
        <classes>
            <class name="com.cts.mfrp.oneappetite.tests.LoginTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.ForgotPasswordTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.CreateAccountTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.ThemeTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.NotificationsTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.LocationSelectionTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.VendorListTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.MenuTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.OrderTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.MyOrdersTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.EmployeeSettingsTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.VendorDashboardTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.VendorMenuMgmtTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.VendorSettingsTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.AdminUserMgmtTest"/>
            <class name="com.cts.mfrp.oneappetite.tests.AdminSettingsTest"/>
        </classes>
    </test>
</suite>
